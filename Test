```python
from dataclasses import dataclass, field
from enum import Enum
from typing import Optional

class FixTier(Enum):
    KB_EXACT       = 1
    NEXUSIQ_API    = 2
    MAVEN_SAFE_VER = 3
    EXCLUSION      = 4
    ACS_OVERLAY    = 5
    NO_FIX         = 99

@dataclass
class Vulnerability:
    group_id:        str
    artifact_id:     str
    current_version: str
    cve_ids:         list[str]
    is_transitive:   bool
    parent_chain:    list[str]   # which deps pull this in
    severity:        str         # CRITICAL / HIGH / MEDIUM / LOW

@dataclass
class FixDecision:
    vuln:               Vulnerability
    tier:               FixTier
    safe_version:       Optional[str]
    use_exclusion:      bool
    exclusion_targets:  list[str]
    bom_managed:        bool
    patch_property:     Optional[str]
    confidence:         float
    reason:             str
```

