rm -f "$COLLISION_STATE_FILE"
# OR
> "$ATTEMPTED_FILE"    # truncate
```

### 3.2  Replace delete with archive in that block

**Do NOT delete. Move to an archive folder instead.**

```bash
# ARCHIVE HELPER — add this function once, near other helper
# functions in the script. Do not add it inside a loop.

archive_state_file() {
    local file_path="$1"
    local archive_base="$2"    # the archive root directory

    # Only archive if the file actually exists and is non-empty
    if [ ! -f "$file_path" ] || [ ! -s "$file_path" ]; then
        return 0
    fi

    # Build archive subdirectory using timestamp of the file
    # so each session's archive is clearly separated
    local file_timestamp
    file_timestamp=$(python3 -c "
import os, datetime
t = os.path.getmtime('$file_path')
print(datetime.datetime.fromtimestamp(t).strftime('%Y%m%d_%H%M%S'))
" 2>/dev/null || date '+%Y%m%d_%H%M%S')

    local archive_dir="$archive_base/session_${file_timestamp}"
    mkdir -p "$archive_dir"

    # Move the file — preserves content, frees the path for new session
    mv "$file_path" "$archive_dir/$(basename "$file_path")"
    log "[ARCHIVE] $(basename "$file_path") → $archive_dir"
}
```

