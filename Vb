```python
def filter_already_patched_vulns(vulns, pom_path, iteration_num):
    """
    Call only when iteration_num > 1.
    Removes vulns whose artifact is already at a different version
    in the current on-disk POM (meaning a previous iteration fixed it).
    Keeps transitives (no direct POM entry to diff against).
    """
    if iteration_num <= 1:
        return vulns

    try:
        tree = ET.parse(pom_path)
        root = tree.getroot()
        ns   = detect_namespace(root)
    except ET.ParseError:
        return vulns    # unreadable POM — pass all, fail safely

    current = {}
    for dep in root.findall(f".//{ns}dependency"):
        g = dep.findtext(f"{ns}groupId",    "").strip()
        a = dep.findtext(f"{ns}artifactId", "").strip()
        v = dep.findtext(f"{ns}version",    "").strip()
        if g and a and v:
            current[f"{g}:{a}"] = v

    remaining = []
    for vuln in vulns:
        ga  = f"{vuln.group_id}:{vuln.artifact_id}"
        ver = current.get(ga)
        if ver is None:
            remaining.append(vuln)   # transitive — keep
        elif ver == vuln.current_version:
            remaining.append(vuln)   # still vulnerable — keep
        # else: already patched — skip

    return remaining
```

