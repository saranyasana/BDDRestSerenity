def find_best_fixable_combination(vulns, triage_map, pom_path,
                                   attempted_artifacts, kb_path):
    """
    When normal resolution produces zero apply-able fixes:
    1. Try each vuln independently with relaxed collision rules
    2. Pick the subset that can all be applied without conflicting
    3. Apply that subset — partial fix is always better than no fix
    4. Never apply a fix that was previously rolled back
    """
    candidates = []

    for vuln in vulns:
        ga = f"{vuln.group_id}:{vuln.artifact_id}"
        triage = triage_map.get(ga, {})

        # Try every tier independently
        for tier_fn in [try_kb, try_nexusiq, try_maven_central,
                        try_exclusion]:
            decision = tier_fn(vuln, triage, pom_path, kb_path)
            if decision and decision.safe_version:
                candidates.append(decision)
                break   # take first successful tier for this vuln

    if not candidates:
        return []

    # Remove conflicts: same GA targeted at different versions
    # Keep higher semver winner
    clean = {}
    for d in candidates:
        ga = f"{d.vuln.group_id}:{d.vuln.artifact_id}"
        if ga not in clean:
            clean[ga] = d
        else:
            existing = safe_version_parse(clean[ga].safe_version)
            current  = safe_version_parse(d.safe_version)
            if current and existing and current > existing:
                clean[ga] = d

    return list(clean.values())


# In process_all_vulnerabilities(), after normal resolution:
if not apply_list:
    log.info("Normal resolution produced zero fixes. "
             "Attempting best-combination fallback.")
    apply_list = find_best_fixable_combination(
        remaining_vulns, triage_map, pom_path,
        attempted_artifacts, kb_path
    )
    if apply_list:
        log.info(f"Best-combination fallback found "
                 f"{len(apply_list)} fixable vulnerabilities.")
    else:
        log.info("No fixable combination found. Converged.")
