## OLLAMA CALL IMPLEMENTATION (Python Reference)

```python
import requests
import json
import re

OLLAMA_HOST = "http://localhost:11434"
OLLAMA_MODEL = "qwen2.5-coder:7b"

def call_ollama(prompt: str, max_retries: int = 2) -> dict:
    """
    Call Ollama and return parsed JSON decision.
    Retries once with stricter instruction if JSON parse fails.
    """
    for attempt in range(max_retries):
        try:
            response = requests.post(
                f"{OLLAMA_HOST}/api/generate",
                json={
                    "model": OLLAMA_MODEL,
                    "prompt": prompt if attempt == 0 else prompt + "\n\nIMPORTANT: Return ONLY the JSON object. No markdown. No backticks. No explanation.",
                    "stream": False,
                    "options": {
                        "temperature": 0.1,
                        "num_predict": 1024,
                        "stop": ["\n\n\n"]
                    }
                },
                timeout=120
            )
            response.raise_for_status()
            raw = response.json()["response"]
            
            # Strip markdown code fences if present
            raw = re.sub(r"```json\s*", "", raw)
            raw = re.sub(r"```\s*", "", raw)
            raw = raw.strip()
            
            # Extract JSON object
            match = re.search(r'\{.*\}', raw, re.DOTALL)
            if match:
                return json.loads(match.group())
                
        except (json.JSONDecodeError, KeyError) as e:
            if attempt == max_retries - 1:
                return {
                    "strategy": "skip",
                    "confidence": 0,
                    "skipReason": f"Ollama response unparseable after {max_retries} attempts: {e}"
                }
    return {"strategy": "skip", "confidence": 0, "skipReason": "Ollama call failed"}


def build_ollama_prompt(vuln: dict, pom_content: str, dep_tree: str,
                         acs_recommendation: str = None,
                         kb_hint: str = None,
                         previous_attempts: list = None,
                         build_error: str = None) -> str:
    """
    Assemble the full Ollama prompt with all context.
    """
    prompt = f"""You are a Maven security remediation expert. Return ONLY valid JSON. No explanation outside JSON.

TASK: Determine the safest pom.xml fix for the vulnerability below.

VULNERABLE ARTIFACT:
  groupId: {vuln['groupId']}
  artifactId: {vuln['artifactId']}
  currentVersion: {vuln['version']}
  CVE: {vuln.get('cve', 'N/A')}
  Severity: {vuln.get('severity', 'UNKNOWN')}
  CVE Description: {vuln.get('description', 'See NexusIQ report')}
"""
    if acs_recommendation:
        prompt += f"\nACS RECOMMENDED VERSION: {acs_recommendation}\nTreat this as a strong hint. Verify compatibility before using.\n"

    if kb_hint:
        prompt += f"\nKB HINT (worked in similar repos before): {kb_hint}\nPrefer this if compatible.\n"

    if previous_attempts:
        attempts_str = "\n".join([f"  - Tried {a['version']}: {a['error']}" for a in previous_attempts])
        prompt += f"\nPREVIOUS FAILED ATTEMPTS (do NOT repeat these):\n{attempts_str}\n"

    if build_error:
        prompt += f"\nLAST BUILD ERROR (caused by previous fix — adjust accordingly):\n{build_error}\n"

    prompt += f"""
CURRENT POM.XML:
{pom_content}

MAVEN DEPENDENCY TREE:
{dep_tree}

RULES:
1. If artifact is managed by parent BOM → use <dependencyManagement> override
2. If direct dependency → update <version> tag directly
3. If transitive only → use <dependencyManagement> or <exclusion> + direct dep
4. Never downgrade below CVE fix version
5. Maintain Spring Boot parent compatibility
6. ACS recommendation is a strong hint — use it unless evidence of breakage
7. If no safe fix exists → set strategy to "skip"
8. If fixing breaks another dependency irreparably → set confidence below 40

Respond ONLY with this JSON:
{{
  "groupId": "{vuln['groupId']}",
  "artifactId": "{vuln['artifactId']}",
  "fixVersion": "version string",
  "strategy": "direct|dependencyManagement|exclusion|bom_property|skip",
  "confidence": <0-100>,
  "xmlChange": "<complete valid XML block>",
  "placement": "dependencies|dependencyManagement|properties",
  "reasoning": "one sentence",
  "skipReason": "only if strategy is skip"
}}"""
    return prompt


def is_real_build_success(log_path: str) -> bool:
    """
    True Maven build success check — scans log for compilation errors
    that Maven sometimes misses in exit code.
    """
    failure_patterns = [
        "COMPILATION ERROR",
        "ClassNotFoundException",
        "NoSuchMethodError",
        "NoSuchFieldError",
        "package does not exist",
        "cannot find symbol",
        "error: incompatible types",
        "BUILD FAILURE"
    ]
    with open(log_path, 'r', errors='ignore') as f:
        log_content = f.read()
    
    for pattern in failure_patterns:
        if pattern in log_content:
            return False
    return "BUILD SUCCESS" in log_content
