def nexusiq_request_with_retry(url, headers, timeout=30, max_attempts=3):
    """
    Drop-in replacement for requests.get() calls to NexusIQ.
    Returns response or None — never raises on network error.
    """
    import time
    for attempt in range(max_attempts):
        try:
            resp = requests.get(url, headers=headers, timeout=timeout)
            resp.raise_for_status()
            return resp
        except (requests.Timeout, requests.ConnectionError):
            if attempt < max_attempts - 1:
                time.sleep(2 ** attempt)
            else:
                return None
        except requests.HTTPError as e:
            return None
    return None
