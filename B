```python
def safe_version_parse(version_str):
    from packaging.version import Version, InvalidVersion
    if not version_str:
        return None
    cleaned = (str(version_str)
               .replace('.Final', '').replace('.RELEASE', '')
               .replace('.GA', '').replace('-SNAPSHOT', '').strip())
    try:
        return Version(cleaned)
    except InvalidVersion:
        import re
        numeric = re.match(r'[\d.]+', cleaned)
        try:
            return Version(numeric.group()) if numeric else None
        except (InvalidVersion, AttributeError):
            return None
```

